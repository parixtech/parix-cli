{
  "name": "@parix/parix",
  "description": "Parix command line interface",
  "type": "module",
  "version": "0.1.0",
  "bin": "./dist/cli.cjs",
  "files": [
    "dist"
  ],
  "packageManager": "bun@1.3.12",
  "homepage": "https://github.com/parixtech/parix-cli#readme",
  "bugs": {
    "url": "https://github.com/parixtech/parix-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parixtech/parix-cli.git"
  },
  "keywords": [
    "parix",
    "cli",
    "parix",
    "database",
    "tigerbeetle"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "zshy",
    "build:link": "zshy && bun link",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "cli": "node ./dist/cli.cjs",
    "pack:dry-run": "npm pack --dry-run --cache .npm-cache",
    "publish:check": "bun run lint && bun run typecheck && bun run build && npm run pack:dry-run",
    "prepublishOnly": "bun run publish:check",
    "publish:npm": "npm publish --access public --cache .npm-cache",
    "prepare": "husky"
  },
  "zshy": {
    "bin": "./src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.9.3",
    "zshy": "^0.7.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxlint --fix src"
    ]
  }
}